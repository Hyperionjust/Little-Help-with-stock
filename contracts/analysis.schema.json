{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://equity-research-suite.local/analysis.schema.json",
  "title": "equity-research-suite — analysis.json（引擎 → 分析师 契约）",
  "description": "唯一数据真源。Markdown/HTML/Excel/PDF 全部由它渲染，分析师层只能从它取数。v1.0 相对 stock-metrics-pro v0：新增 statements/segments/peers/estimates/capital_structure 五块，并吸收 xtt datasource-router 的溯源模型（connector_status / fallback_trail / evidence_class / lineage）。新增块暂不列入 required——引擎按阶段逐步产出，但一旦出现就必须合规。",
  "type": "object",
  "required": [
    "schema_version",
    "meta",
    "resolution",
    "quote",
    "valuation",
    "profitability",
    "reverse_validation",
    "solvency",
    "growth",
    "technicals",
    "quality_report",
    "data_gaps"
  ],
  "additionalProperties": true,
  "definitions": {
    "annotated_value": {
      "type": "object",
      "description": "Three-part provenance: source name, collection timestamp, formula/basis.",
      "required": [
        "value",
        "source",
        "as_of",
        "formula"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string",
          "description": "provider.interface, e.g. 'akshare.stock_zh_a_hist'"
        },
        "as_of": {
          "type": [
            "string",
            "null"
          ],
          "description": "ISO8601 collection/data timestamp"
        },
        "formula": {
          "type": "string",
          "description": "计算公式或口径说明"
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "period": {
          "type": [
            "string",
            "null"
          ],
          "description": "报告期区间, e.g. 'TTM 2023Q4-2024Q3'"
        }
      },
      "additionalProperties": true
    },
    "pharma_assumption": {
      "type": "object",
      "required": [
        "value",
        "source",
        "as_of",
        "formula",
        "source_type"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        },
        "as_of": {
          "type": [
            "string",
            "null"
          ]
        },
        "formula": {
          "type": "string"
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "hard",
            "benchmark",
            "user_assumption"
          ]
        }
      },
      "additionalProperties": true
    },
    "connector_status": {
      "type": "string",
      "description": "Connector 诚实规则：这个数据到底是真调到了、只有接口描述、用户手填、还是压根没有。",
      "enum": [
        "live_provider",
        "contract_only",
        "user_supplied",
        "missing_required_source"
      ]
    },
    "evidence_class": {
      "type": "string",
      "description": "证据分级。engine 层用 hard/benchmark/user_assumption 做门禁，此处为对外溯源展示口径。",
      "enum": [
        "official_record",
        "provider_observation",
        "provider_estimate",
        "user_input",
        "derived_value",
        "stale_value",
        "disputed",
        "unresolved"
      ]
    },
    "lineage_item": {
      "type": "object",
      "description": "字段级血缘。source_unit 与集中化单位归一化配套（方案 §4.3）。",
      "required": [
        "field",
        "dataset",
        "retrieved_at"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "provider_field": {
          "type": [
            "string",
            "null"
          ],
          "description": "上游原始字段名"
        },
        "dataset": {
          "type": "string"
        },
        "retrieved_at": {
          "type": "string"
        },
        "effective_date": {
          "type": [
            "string",
            "null"
          ],
          "description": "数据本身的口径日期，非采集日期"
        },
        "source_currency": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_unit": {
          "type": [
            "string",
            "null"
          ],
          "description": "归一化前的原始单位，如 元/亿元/million"
        },
        "evidence_class": {
          "$ref": "#/definitions/evidence_class"
        },
        "transformation_note": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "fallback_item": {
      "type": "object",
      "description": "源切换记录。永远在场——源的变更绝不静默。",
      "required": [
        "planned_provider",
        "actual_provider"
      ],
      "properties": {
        "field_group": {
          "type": [
            "string",
            "null"
          ]
        },
        "planned_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "actual_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverage_limitations": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "diagnostic": {
      "type": "object",
      "description": "结构化诊断对象（方案 §12.2）。user_action_* 同时是引导层在失败路径上的内容源。",
      "required": [
        "layer",
        "stage",
        "code",
        "severity"
      ],
      "properties": {
        "layer": {
          "type": "string",
          "enum": [
            "engine",
            "analyst",
            "publisher"
          ]
        },
        "stage": {
          "type": "string"
        },
        "code": {
          "type": "string",
          "description": "稳定错误码，见 references/error-codes.json"
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "warning",
            "info"
          ]
        },
        "message_zh": {
          "type": "string"
        },
        "message_en": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true
        },
        "agent_action": {
          "type": [
            "string",
            "null"
          ],
          "description": "约束 LLM：该重试/换源/降级/停止"
        },
        "user_action_zh": {
          "type": [
            "string",
            "null"
          ],
          "description": "告诉用户他能做什么——把死路变岔路"
        },
        "user_action_en": {
          "type": [
            "string",
            "null"
          ]
        },
        "retriable": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "statement_period": {
      "type": "object",
      "required": [
        "period",
        "_meta"
      ],
      "properties": {
        "period": {
          "type": "string",
          "description": "如 2024FY / 2025Q1"
        },
        "_meta": {
          "type": "object",
          "required": [
            "source",
            "as_of",
            "currency",
            "unit"
          ],
          "properties": {
            "source": {
              "type": "string"
            },
            "as_of": {
              "type": "string"
            },
            "accounting_standard": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "CAS",
                "IFRS",
                "US_GAAP",
                null
              ]
            },
            "currency": {
              "type": "string"
            },
            "unit": {
              "type": "string",
              "enum": [
                "ones",
                "thousands",
                "million",
                "billion"
              ],
              "description": "归一化后的统一单位；原始单位记在 lineage.source_unit"
            },
            "evidence_class": {
              "$ref": "#/definitions/evidence_class"
            }
          },
          "additionalProperties": true
        },
        "income_statement": {
          "type": "object",
          "properties": {
            "revenue": {
              "type": [
                "number",
                "null"
              ]
            },
            "cogs": {
              "type": [
                "number",
                "null"
              ]
            },
            "gross_profit": {
              "type": [
                "number",
                "null"
              ]
            },
            "rd_expense": {
              "type": [
                "number",
                "null"
              ]
            },
            "sga_expense": {
              "type": [
