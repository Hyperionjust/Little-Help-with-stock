              ]
            },
            "operating_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "interest_expense": {
              "type": [
                "number",
                "null"
              ]
            },
            "interest_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "pretax_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "tax": {
              "type": [
                "number",
                "null"
              ]
            },
            "net_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "minority_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "eps_basic": {
              "type": [
                "number",
                "null"
              ]
            },
            "eps_diluted": {
              "type": [
                "number",
                "null"
              ]
            },
            "shares_basic": {
              "type": [
                "number",
                "null"
              ]
            },
            "shares_diluted": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "balance_sheet": {
          "type": "object",
          "properties": {
            "cash": {
              "type": [
                "number",
                "null"
              ]
            },
            "short_term_investments": {
              "type": [
                "number",
                "null"
              ]
            },
            "accounts_receivable": {
              "type": [
                "number",
                "null"
              ]
            },
            "inventory": {
              "type": [
                "number",
                "null"
              ]
            },
            "current_assets": {
              "type": [
                "number",
                "null"
              ]
            },
            "ppe_net": {
              "type": [
                "number",
                "null"
              ]
            },
            "goodwill": {
              "type": [
                "number",
                "null"
              ]
            },
            "intangibles": {
              "type": [
                "number",
                "null"
              ]
            },
            "total_assets": {
              "type": [
                "number",
                "null"
              ]
            },
            "accounts_payable": {
              "type": [
                "number",
                "null"
              ]
            },
            "short_term_debt": {
              "type": [
                "number",
                "null"
              ]
            },
            "current_liabilities": {
              "type": [
                "number",
                "null"
              ]
            },
            "long_term_debt": {
              "type": [
                "number",
                "null"
              ]
            },
            "total_debt": {
              "type": [
                "number",
                "null"
              ]
            },
            "total_liabilities": {
              "type": [
                "number",
                "null"
              ]
            },
            "minority_interest": {
              "type": [
                "number",
                "null"
              ]
            },
            "equity": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "cash_flow": {
          "type": "object",
          "properties": {
            "net_income": {
              "type": [
                "number",
                "null"
              ]
            },
            "depreciation_amortization": {
              "type": [
                "number",
                "null"
              ]
            },
            "stock_based_comp": {
              "type": [
                "number",
                "null"
              ]
            },
            "change_in_wc": {
              "type": [
                "number",
