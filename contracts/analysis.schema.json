              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "meta": {
      "type": "object",
      "required": [
        "generated_at",
        "generator",
        "adjust_mode",
        "disclaimer"
      ],
      "properties": {
        "generated_at": {
          "type": "string"
        },
        "generator": {
          "type": "string"
        },
        "adjust_mode": {
          "type": "string",
          "enum": [
            "qfq",
            "hfq",
            "none",
            "unknown"
          ],
          "description": "复权口径；none/unknown 触发 warning"
        },
        "accounting_standard": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "CAS",
            "IFRS",
            "US_GAAP",
            null
          ]
        },
        "base_currency": {
          "type": [
            "string",
            "null"
          ]
        },
        "disclaimer": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "resolution": {
      "type": "object",
      "required": [
        "market",
        "symbol",
        "name",
        "currency",
        "exchange",
        "is_pharma"
      ],
      "properties": {
        "market": {
          "type": "string",
          "enum": [
            "A",
            "HK",
            "US"
          ]
        },
        "symbol": {
          "type": "string"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "currency": {
          "type": "string"
        },
        "exchange": {
          "type": [
            "string",
            "null"
          ]
        },
        "industry_tag": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_pharma": {
          "type": "boolean"
        },
        "benchmark_index": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "quote": {
      "type": "object",
      "required": [
        "price",
        "market_cap"
      ],
      "properties": {
        "price": {
          "$ref": "#/definitions/annotated_value"
        },
        "market_cap": {
          "$ref": "#/definitions/annotated_value"
        },
        "prev_close": {
          "$ref": "#/definitions/annotated_value"
        },
        "cross_source_check": {
          "type": "object",
          "description": "跨源价格校验",
          "properties": {
            "sources": {
              "type": "object"
            },
            "max_rel_diff": {
              "type": [
                "number",
                "null"
              ]
            },
            "passed": {
              "type": [
                "boolean",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "valuation": {
      "type": "object",
      "properties": {
        "pe_ttm": {
          "$ref": "#/definitions/annotated_value"
        },
        "pe_static": {
          "$ref": "#/definitions/annotated_value"
        },
        "pe_forward": {
          "$ref": "#/definitions/annotated_value"
        },
        "pb": {
          "$ref": "#/definitions/annotated_value"
        },
        "ps_ttm": {
