            "ttm",
            "static",
            "forward"
          ]
        }
      },
      "additionalProperties": true
    },
    "profitability": {
      "type": "object",
      "properties": {
        "roe": {
          "$ref": "#/definitions/annotated_value"
        },
        "roa": {
          "$ref": "#/definitions/annotated_value"
        },
        "roic": {
          "$ref": "#/definitions/annotated_value"
        },
        "gross_margin": {
          "$ref": "#/definitions/annotated_value"
        },
        "net_margin": {
          "$ref": "#/definitions/annotated_value"
        },
        "cash_content": {
          "$ref": "#/definitions/annotated_value"
        },
        "dupont": {
          "type": "object",
          "description": "杜邦三分解，三因子乘积应≈ROE",
          "properties": {
            "net_margin": {
              "$ref": "#/definitions/annotated_value"
            },
            "asset_turnover": {
              "$ref": "#/definitions/annotated_value"
            },
            "equity_multiplier": {
              "$ref": "#/definitions/annotated_value"
            },
            "product_check": {
              "$ref": "#/definitions/annotated_value"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "reverse_validation": {
      "type": "object",
      "description": "逆向验证：揭示利润好看但现金流/资产质量恶化",
      "properties": {
        "ar_vs_revenue_growth": {
          "$ref": "#/definitions/annotated_value"
        },
        "inventory_vs_revenue_growth": {
          "$ref": "#/definitions/annotated_value"
        },
        "ocf_ni_divergence_3y": {
          "$ref": "#/definitions/annotated_value"
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "solvency": {
      "type": "object",
