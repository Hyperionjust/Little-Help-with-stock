        },
        "support_resistance": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "pharma": {
      "type": "object",
      "description": "仅医药标的存在",
      "required": [
        "paradigm",
        "rnpv",
        "pipeline",
        "human_verification_checklist"
      ],
      "properties": {
        "paradigm": {
          "type": "string",
          "enum": [
            "commercial",
            "clinical_biotech",
            "large_pharma_sotp"
          ]
        },
        "clinical_discount_rate": {
          "$ref": "#/definitions/pharma_assumption"
        },
        "wacc_general": {
          "$ref": "#/definitions/annotated_value"
        },
        "double_penalty_check": {
          "type": "object",
          "required": [
            "clinical_rate_is_independent",
            "passed"
          ],
          "properties": {
            "clinical_rate_is_independent": {
              "type": "boolean"
            },
            "clinical_rate": {
              "type": [
                "number",
                "null"
              ]
            },
            "wacc": {
              "type": [
                "number",
                "null"
              ]
            },
            "passed": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "rnpv": {
          "type": "object",
          "required": [
            "company_rnpv",
            "assets"
          ],
          "properties": {
            "company_rnpv": {
              "$ref": "#/definitions/annotated_value"
            },
            "net_cash": {
              "$ref": "#/definitions/annotated_value"
            },
            "debt": {
              "$ref": "#/definitions/annotated_value"
            },
            "sum_asset_rnpv": {
              "$ref": "#/definitions/annotated_value"
