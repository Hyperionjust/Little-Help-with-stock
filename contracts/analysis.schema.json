      "properties": {
        "moving_averages": {
          "type": "object"
        },
        "ma_alignment": {
          "$ref": "#/definitions/annotated_value"
        },
        "macd": {
          "type": "object"
        },
        "rsi": {
          "type": "object"
        },
        "kdj": {
          "type": "object"
        },
        "bias": {
          "type": "object"
        },
        "atr": {
          "$ref": "#/definitions/annotated_value"
        },
        "volatility_20d": {
          "$ref": "#/definitions/annotated_value"
        },
        "volume_ratio": {
